' ========================================================
' 9. External Frameworks & Libraries / Shared DLL (DynamicDll.Db)
' ========================================================
package "Microsoft.AspNetCore.Mvc.Filters" {
    abstract class ActionFilterAttribute {
        + Order : int <<get>> <<set>>
        + <<virtual>> OnActionExecuted(context:ActionExecutedContext) : void
        + <<virtual>> OnActionExecuting(context:ActionExecutingContext) : void
        + <<virtual>> OnActionExecutionAsync(context:ActionExecutingContext, next:ActionExecutionDelegate) : Task
        + <<virtual>> OnResultExecuted(context:ResultExecutedContext) : void
        + <<virtual>> OnResultExecuting(context:ResultExecutedContext) : void
        + <<virtual>> OnResultExecutionAsync(context:ResultExecutedContext, next:ResultExecutionDelegate) : Task
    }
    interface IActionFilter
    interface IFilterMetadata
    interface IAsyncActionFilter
    interface IResultFilter
    interface IAsyncResultFilter
    interface IOrderedFilter
}

package "DynamicDll.Db" {
    abstract class "BaseDao`1"<T> {
        # con : SqlConnection
        # trn : SqlTransaction
        # BaseDao()
        + {abstract} Find(params pkeys:object[]) : T
        + {abstract} Insert(entity:T) : int
        + {abstract} Update(entity:T) : int
        + {abstract} Delete(entity:T) : int
        # GetString(fieldValue:object) : string
        # GetInt(fieldValue:object) : int?
        # GetDouble(fieldValue:object) : double?
        # GetDateTime(fieldValue:object) : DateTime?
    }

    class TranMng {
        + {static} Transaction : SqlTransaction <<get>>
        + {static} BeginTransaction(connectionKey:string) : TranMng
        + Commit() : void
        + Rollback() : void
    }
}

