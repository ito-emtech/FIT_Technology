@startuml ClassList
title システムクラス定義一覧 (AccountDao 基底クラス・実装依存反映版)

' ========================================================
' 1. FIT_Technology.Controllers (画面制御・MVCコントローラー)
' ========================================================
package "FIT_Technology.Controllers" {
    class AccountController {
        + Index() : IActionResult
        + Login() : IActionResult
