' ========================================================
' 9. External Frameworks & Libraries / Shared DLL (DynamicDll.Db)
' ========================================================
package "Microsoft.AspNetCore.Mvc.Filters" {
    abstract class ActionFilterAttribute {
        note right: Framework共通クラスのため\n内部インターフェース関係線は省略
    }
}

package "Microsoft.Extensions.DependencyInjection" {
    class ServiceCollectionServiceExtensions <<static>> {
        + {static} AddKeyedScoped(services:IServiceCollection, serviceType:Type, serviceKey:object?) : IServiceCollection
        note bottom: AddScoped などの拡張メソッド定義元
    }
}

package "DynamicDll.Db" {
    abstract class "BaseDao`1"<T> {
        # con : SqlConnection
        # trn : SqlTransaction
        # BaseDao()
        + {abstract} Find(params pkeys:object[]) : T
        + {abstract} Insert(entity:T) : int
        + {abstract} Update(entity:T) : int
        + {abstract} Delete(entity:T) : int
        # GetString(fieldValue:object) : string
        # GetInt(fieldValue:object) : int?
        # GetDouble(fieldValue:object) : double?
        # GetDateTime(fieldValue:object) : DateTime?
    }

    class TranMng {
        + {static} Transaction : SqlTransaction <<get>>
        + {static} BeginTransaction(connectionKey:string) : TranMng
        + Commit() : void
        + Rollback() : void
    }
}

