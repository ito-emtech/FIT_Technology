        + <<[Column("first_nm_kana", TypeName="nvarchar")]>> FirstNmKana : string <<get>> <<set>>
        + <<[Column("gender_cd", TypeName="int")]>> GenderCd : int <<get>> <<set>>
        + <<[Column("birth_date", TypeName="date")]>> BirthDate : DateTime <<get>> <<set>>
        + <<[Column("section_cd", TypeName="char")]>> SectionCd : string <<get>> <<set>>
