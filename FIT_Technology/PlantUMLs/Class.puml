@startuml ClassList
title システムクラス定義一覧 (View 構造整合性確認済)
' 関係線に説明文を追加

' ========================================================
' 0. アプリケーション・エントリーポイント
' ========================================================
class Program <<(⚡, #FF7700) static>> {
    note top: アプリケーション起動構成\nサービス登録(DI)・ミドルウェア設定
}

' ========================================================
' 1. FIT_Technology.Controllers (画面制御・MVCコントローラー)
' ========================================================
package "FIT_Technology.Controllers" {
    class AccountController {
        {-} service : AccountService
        + AccountController(service:AccountService)
        + Index() : IActionResult
        + Login() : IActionResult
        + Login(user:UserEntity) : IActionResult
        + Logout() : IActionResult
        + Logout(btn_action:string) : IActionResult
        + Menu() : IActionResult
        + Menu(btn_action:string) : IActionResult
    }

    class DemoController <<[SessionCheck]>> {
        {-} _employeeService : DemoEmployeeService
        {-} _licenseService : DemoGetLicenseService
        + DemoController()
        + Index() : IActionResult
        + LicenseMenu() : IActionResult
        + LicenseMenu(btn_action:string, emp_cd:string) : IActionResult
        + EmployeeInsert() : IActionResult
        + EmployeeInsert(entity:EmployeeEntity) : IActionResult
        + Insert() : IActionResult
        + Insert(entity:GetLicenseEntity) : IActionResult
        + List() : IActionResult
        + List(btn_action:string, license_cd:string[]) : IActionResult
        + Alert() : IActionResult
        + Alert(entities:List<GetLicenseEntity>) : IActionResult
    }

    class DemoController::TempKeys <<static>> {
        + <<const>> CreateEmployee : string = "createEmployee"
        + <<const>> DeleteLicense : string = "deleteLicense"
        + <<const>> TargetEmpCd : string = "targetEmpCd"
    }

    class EmployeeController <<[SessionCheck]>> {
        + Index() : IActionResult
        + List() : IActionResult
        + List(empcd:List<string>, btn_action:string) : IActionResult
        + Insert() : IActionResult
        + Insert(employee:EmployeeEntity, btn_action:string) : IActionResult
        + Alert() : IActionResult
        + Alert(deleteEmp:List<EmployeeEntity>, btn_action:string) : IActionResult
        + Update() : IActionResult
        + Update(employee:EmployeeEntity, btn_action:string) : IActionResult
    }

    class ResultController {
        + Index() : IActionResult
    }
}

' ========================================================
' 2. FIT_Technology.Filters (カスタム属性・共通フィルタ)
' ========================================================
package "FIT_Technology.Filters" {
    class SessionCheckAttribute {
        + <<override>> OnActionExecuting(context:ActionExecutingContext) : void
    }
}

' ========================================================
' 4. FIT_Technology.Models.Services (業務ロジック)
' ========================================================
package "FIT_Technology.Models.Services" {
    class AccountService {
        + Authenticate(userid:string, password:string) : bool
    }

    class DemoGetLicenseService {
        + GetLicense(empCd:string, licenseCd:string) : GetLicenseEntity
        + GetLicensesByEmpCd(empCd:string) : List<GetLicenseEntity>
        + RegisterLicense(entity:GetLicenseEntity) : bool
        + RemoveLicense(entity:GetLicenseEntity) : bool
        + RemoveLicenses(entities:List<GetLicenseEntity>) : bool
        + GetLicenses() : List<LicenseEntity>
    }

    class DemoEmployeeService {
        + GetEmployees() : List<EmployeeEntity>
        + GetEmployee(empCd:string) : EmployeeEntity
        + RegisterEmployee(entity:EmployeeEntity) : bool
        + GetSections() : List<SectionEntity>
        + GetGenders() : List<GenderEntity>
    }
}

' ========================================================
' 5. FIT_Technology.Models.Daos (データアクセス層)
' ========================================================
package "FIT_Technology.Models.Daos" {
    class AccountDao {
        + AccountDao()
        + <<override>> Find(params pkeys:object[]) : UserEntity
        + <<override>> Insert(entity:UserEntity) : int
        + <<override>> Update(entity:UserEntity) : int
        + <<override>> Delete(entity:UserEntity) : int
    }

    class DemoGetLicenseDao {
        + DemoGetLicenseDao()
        + <<override>> Find(params pkeys:object[]) : GetLicenseEntity
        + FindByEmpCd(empCd:string) : List<GetLicenseEntity>
        + <<override>> Insert(entity:GetLicenseEntity) : int
        + <<override>> Update(entity:GetLicenseEntity) : int
        + <<override>> Delete(entity:GetLicenseEntity) : int
    }

    class DemoEmployeeDao {
        + DemoEmployeeDao()
        + <<override>> Find(params pkeys:object[]) : EmployeeEntity
        + FindAll() : List<EmployeeEntity>
        + <<override>> Insert(entity:EmployeeEntity) : int
        + <<override>> Update(entity:EmployeeEntity) : int
        + <<override>> Delete(entity:EmployeeEntity) : int
    }

    class EmployeeDao {
        + EmployeeDao()
        + <<override>> Find(params pkeys:object[]) : EmployeeEntity
        + <<override>> Insert(entity:EmployeeEntity) : int
        + <<override>> Update(entity:EmployeeEntity) : int
        + <<override>> Delete(entity:EmployeeEntity) : int
        + FindAll() : List<EmployeeEntity>
        + Exists(empcd:string) : bool
    }

    class GenderDao {
        + GenderDao()
        + <<override>> Find(params pkeys:object[]) : GenderEntity
        + FindAll() : List<GenderEntity>
        + <<override>> Insert(entity:GenderEntity) : int
        + <<override>> Update(entity:GenderEntity) : int
        + <<override>> Delete(entity:GenderEntity) : int
    }

    class GetLicenseDao {
        + GetLicenseDao()
        + <<override>> Find(params pkeys:object[]) : GetLicenseEntity
        + FindAll() : List<GetLicenseEntity>
        + FindWhere(emp_cd:string) : List<GetLicenseEntity>
        + <<override>> Insert(entity:GetLicenseEntity) : int
        + <<override>> Update(entity:GetLicenseEntity) : int
        + <<override>> Delete(entity:GetLicenseEntity) : int
    }

    class LicenseDao {
        + LicenseDao()
        + <<override>> Find(params pkeys:object[]) : LicenseEntity
        + FindAll() : List<LicenseEntity>
        + <<override>> Insert(entity:LicenseEntity) : int
        + <<override>> Update(entity:LicenseEntity) : int
        + <<override>> Delete(entity:LicenseEntity) : int
    }

    class SectionDao {
        + SectionDao()
        + <<override>> Find(params pkeys:object[]) : SectionEntity
        + FindAll() : List<SectionEntity>
        + <<override>> Insert(entity:SectionEntity) : int
        + <<override>> Update(entity:SectionEntity) : int
        + <<override>> Delete(entity:SectionEntity) : int
    }
}

' ========================================================
' 6. FIT_Technology.Models.Entities (ドメインモデル)
' ========================================================
package "FIT_Technology.Models.Entities" {
    class EmployeeEntity <<[Table("m_employee")]>> <<[Serializable]>> {
        + <<[Key]>> <<[Column("emp_cd", TypeName="char")]>> EmpCd : string <<get>> <<set>>
        + <<[Column("last_nm", TypeName="nvarchar")]>> LastNm : string <<get>> <<set>>
        + <<[Column("first_nm", TypeName="nvarchar")]>> FirstNm : string <<get>> <<set>>
        + <<[Column("last_nm_kana", TypeName="nvarchar")]>> LastNmKana : string <<get>> <<set>>
        + <<[Column("first_nm_kana", TypeName="nvarchar")]>> FirstNmKana : string <<get>> <<set>>
        + <<[Column("gender_cd", TypeName="int")]>> GenderCd : int <<get>> <<set>>
        + <<[Column("birth_date", TypeName="date")]>> BirthDate : DateTime <<get>> <<set>>
        + <<[Column("section_cd", TypeName="char")]>> SectionCd : string <<get>> <<set>>
        + <<[Column("emp_date", TypeName="date")]>> EmpDate : DateTime <<get>> <<set>>
        + <<[Column("created", TypeName="datetime2")]>> <<[DatabaseGenerated(Identity)]>> Created : DateTime <<get>> <<set>>
        + <<[Column("updated", TypeName="datetime2")]>> <<[DatabaseGenerated(Computed)]>> Updated : DateTime <<get>> <<set>>
    }

    class GenderEntity <<[Table("m_gender")]>> <<[Serializable]>> {
        + <<[Key]>> <<[Column("gender_cd", TypeName="int")]>> GenderCd : int <<get>> <<set>>
        + <<[Column("gender_nm", TypeName="nvarchar")]>> GenderNm : string <<get>> <<set>>
    }

    class GetLicenseEntity <<[Table("t_get_license")]>> <<[Serializable]>> {
        + <<[Key]>> <<[Column("emp_cd", Order=0, TypeName="char")]>> EmpCd : string <<get>> <<set>>
        + <<[Key]>> <<[Column("license_cd", Order=1, TypeName="char")]>> LicenseCd : string <<get>> <<set>>
        + <<[Column("get_license_date", TypeName="date")]>> GetLicenseDate : DateTime <<get>> <<set>>
        + <<[Column("created", TypeName="datetime2")]>> <<[DatabaseGenerated(Identity)]>> Created : DateTime <<get>> <<set>>
        + <<[Column("updated", TypeName="datetime2")]>> <<[DatabaseGenerated(Computed)]>> Updated : DateTime <<get>> <<set>>
        + <<[Column("license_nm")]>> LicenseNm : string <<get>> <<set>>
        + <<[NotMapped]>> DisplayLicenseText : string <<get>>
    }

    class LicenseEntity <<[Table("m_license")]>> <<[Serializable]>> {
        + <<[Key]>> <<[Column("license_cd", TypeName="char")]>> LicenseCd : string <<get>> <<set>>
        + <<[Column("license_nm", TypeName="nvarchar")]>> LicenseNm : string <<get>> <<set>>
        + <<[NotMapped]>> DisplayLicenseText : string <<get>>
    }

    class SectionEntity <<[Table("m_section")]>> <<[Serializable]>> {
        + <<[Key]>> <<[Column("section_cd", TypeName="char")]>> SectionCd : string <<get>> <<set>>
        + <<[Column("section_nm", TypeName="nvarchar")]>> SectionNm : string <<get>> <<set>>
    }

    class UserEntity <<[Table("m_user")]>> <<[Serializable]>> {
        + <<[Key]>> <<[Column("user_id", TypeName="varchar")]>> UserId : string <<get>> <<set>>
        + <<[Column("password", TypeName="varchar")]>> Password : string <<get>> <<set>>
        + <<[Column("created", TypeName="datetime2")]>> <<[DatabaseGenerated(Identity)]>> Created : DateTime <<get>> <<set>>
        + <<[Column("updated", TypeName="datetime2")]>> <<[DatabaseGenerated(Computed)]>> Updated : DateTime <<get>> <<set>>
    }
}

' ========================================================
' 9. External Frameworks & Libraries / Shared DLL (DynamicDll.Db)
' ========================================================
package "Microsoft.AspNetCore.Mvc.Filters" {
    abstract class ActionFilterAttribute {
        note right: Framework共通クラスのため\n内部インターフェース関係線は省略
    }
}

package "Microsoft.Extensions.DependencyInjection" {
    class ServiceCollectionServiceExtensions <<static>> {
        + {static} AddKeyedScoped(services:IServiceCollection, serviceType:Type, serviceKey:object?) : IServiceCollection
        note bottom: AddScoped などの拡張メソッド定義元
    }
}

package "DynamicDll.Db" {
    abstract class "BaseDao`1"<T> {
        # con : SqlConnection
        # trn : SqlTransaction
        # BaseDao()
        + {abstract} Find(params pkeys:object[]) : T
        + {abstract} Insert(entity:T) : int
        + {abstract} Update(entity:T) : int
        + {abstract} Delete(entity:T) : int
        # GetString(fieldValue:object) : string
        # GetInt(fieldValue:object) : int?
        # GetDouble(fieldValue:object) : double?
        # GetDateTime(fieldValue:object) : DateTime?
    }

    class TranMng {
        + {static} Transaction : SqlTransaction <<get>>
        + {static} BeginTransaction(connectionKey:string) : TranMng
        + Commit() : void
        + Rollback() : void
    }
}

' ========================================================
' 関係線マッピング
' ========================================================

' --- Program.cs からのマッピング依存関係 ---
Program ..> ServiceCollectionServiceExtensions : 拡張メソッド呼び出し (DIサービス登録)
Program ..> AccountService : スコープ(AddScoped)としてコンテナに登録対象
Program ..> AccountController : デフォルトルートとして指定 ({controller=Account}/{action=Login})

DemoController +-- DemoController::TempKeys

' --- ActionFilter関係の整理 ---
SessionCheckAttribute --|> ActionFilterAttribute

' --- パッケージ間の基本継承関係 ---
"FIT_Technology.Models.Daos" ..> "DynamicDll.Db" : すべてのDaoはBaseDaoを継承

"BaseDao`1" ..> TranMng

' --- AccountController 関連の依存関係（詳細化済） ---
AccountController --> AccountService : Login(HttpPost) 内で\nAuthenticate(id, pass) を実行
AccountController ..> UserEntity : Login(HttpPost) の引数として\n入力データをバインド
AccountController ..> EmployeeController : Menu() から RedirectToAction で遷移
AccountController ..> DemoController : Menu() から RedirectToAction で遷移
AccountController ..> SessionCheckAttribute : Index, Logout, Menu の\nログインセッションチェックに適用

AccountService ..> AccountDao
AccountService ..> TranMng

AccountDao ..> UserEntity

' --- EmployeeController 関連の依存関係（詳細化） ---
EmployeeController ..> SessionCheckAttribute : クラス属性として指定され、\n全アクションでログイン検証を実施
EmployeeController ..> TranMng : 各データアクセス時の\nトランザクション制御 (empdb) に使用
EmployeeController ..> EmployeeDao : FindAll() による全件取得、Exists() による重複確認、\nInsert/Update/Delete の実行
EmployeeController ..> SectionDao : List(HttpGet)、Insert(HttpGet/HttpPost)、\nUpdate(HttpGet/HttpPost) 内でのマスター全件取得
EmployeeController ..> GenderDao : Insert(HttpGet/HttpPost)、\nUpdate(HttpGet/HttpPost) 内でのマスター全件取得
EmployeeController ..> DemoGetLicenseDao : Alert(HttpPost) 内で従業員に紐づく\n保有資格(t_get_license)を事前に一括削除するため使用
EmployeeController ..> EmployeeEntity : 各画面（一覧・登録・変更・削除）の\nバインド、受け渡し、およびDaoの操作対象オブジェクト
EmployeeController ..> SectionEntity : 部署マスターデータの保持
EmployeeController ..> GenderEntity : 性別マスターデータの保持
EmployeeController ..> GetLicenseEntity : 保有資格削除データのハンドリング
EmployeeController ..> ResultController : 各処理の正常完了時や、\nDB例外発生時のエラー表示画面への遷移先
EmployeeController ..> AccountController : 各画面の「戻る」ボタン押下時に\nメニュー画面へ戻る際のリダイレクト先

DemoController ..> SessionCheckAttribute : クラス属性としてセッション検証の強制
DemoController --> DemoEmployeeService : コンストラクタで手動new、従業員・マスタ関連処理の委譲
DemoController --> DemoGetLicenseService : コンストラクタで手動new、保有資格・マスタ関連処理の委譲
DemoController ..> DemoController::TempKeys : 各種TempDataキー(TargetEmpCd等)の内部参照
DemoController ..> EmployeeEntity : EmployeeInsert時のバインド・表示処理
DemoController ..> GetLicenseEntity : 資格登録(Insert)、削除確認(Alert)でのバインド、及びモデル操作

' --- DemoGetLicenseService の依存関係 ---
DemoGetLicenseService ..> TranMng
DemoGetLicenseService --> DemoGetLicenseDao : 生成・利用(new)
DemoGetLicenseService --> LicenseDao : 生成・利用(new)
DemoGetLicenseService ..> GetLicenseEntity
DemoGetLicenseService ..> LicenseEntity

' --- DemoEmployeeService の依存関係 ---
DemoEmployeeService ..> TranMng
DemoEmployeeService --> DemoEmployeeDao : 生成・利用(new)
DemoEmployeeService --> SectionDao : 生成・利用(new)
DemoEmployeeService --> GenderDao : 生成・利用(new)
DemoEmployeeService ..> EmployeeEntity
DemoEmployeeService ..> SectionEntity
DemoEmployeeService ..> GenderEntity

DemoGetLicenseDao ..> GetLicenseEntity : 操作対象型引数・戻り値マッピング先

DemoEmployeeDao ..> EmployeeEntity : 操作対象型引数・戻り値マッピング先

EmployeeDao ..> EmployeeEntity : データの詰め替え・引数および戻り値オブジェクト
EmployeeDao ..> "BaseDao`1" : con, trn メンバへのダイレクトアクセス

GenderDao ..> GenderEntity : 操作対象型引数・戻り値マッピング先

GetLicenseDao ..> GetLicenseEntity : 手動データ詰め替え・引数および戻り値オブジェクト
GetLicenseDao ..> "BaseDao`1" : con, trn メンバへのダイレクトアクセス

SectionDao ..> SectionEntity : 操作対象型引数・戻り値マッピング先

LicenseDao ..> LicenseEntity : 操作対象型引数・戻り値マッピング先

SessionCheckAttribute ..> AccountController

' ========================================================
' パッケージ全体のレイアウト強制
' ========================================================

@enduml