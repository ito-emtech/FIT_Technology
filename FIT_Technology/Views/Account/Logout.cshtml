@{
    Layout = "_Layout";
    ViewBag.Title = "ログアウト確認";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @* タイトルを中央寄せ *@
            <h2 class="text-center mb-4">@ViewBag.Title</h2>

            @* 警告メッセージ *@
            <div class="alert alert-warning text-center">
                本当にログアウトしますか？
            </div>

            <form asp-action="Logout" method="post">
                <div class="d-flex justify-content-center gap-2">
                    <button type="submit" name="btn_action" value="logout" style="min-width: 140px;" class="btn btn-danger">
                        ログアウト実行
                    </button>
                    <button type="submit" name="btn_action" value="cancel" style="min-width: 140px;" class="btn btn-secondary">
                        メニューに戻る
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>