@model FIT_Technology.Models.Entities.UserEntity

@{
    Layout = "_Layout";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center">@ViewBag.Title</h2>

            @* --- メッセージ表示エリア --- *@
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="menu-desc-area" role="alert">
                    <small>@TempData["ErrorMessage"]</small>
                </div>
            }

            @* --- 【追加】ログアウトなどの通知メッセージ表示エリア --- *@
            @if (TempData["InfoMessage"] != null)
            {
                <div class="menu-desc-area" role="alert">
                    <small>@TempData["InfoMessage"]</small>
                </div>
            }
            @* -------------------------- *@

            <form method="post">
                @* 概要エラーの表示場所（省略可） *@
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="UserId" class="form-label"></label>
                    <input asp-for="UserId" class="form-control" />
                    @* バリデーションエラーメッセージの表示 *@
                    <span asp-validation-for="UserId" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Password" class="form-label"></label>
                    <input asp-for="Password" class="form-control" />
                    @* バリデーションエラーメッセージの表示 *@
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <br />
                @* <div class="d-grid"> *@
                <div class="text-center">
                    <button type="submit" class="btn-primary-filled" style="width: 100%; max-width: 180px;">ログイン</button>
                </div>
            </form>
        </div>
    </div>
</div>
