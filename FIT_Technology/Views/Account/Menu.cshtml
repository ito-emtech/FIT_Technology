@using FIT_Technology.Models.Constants
@model FIT_Technology.Models.Entities.UserEntity

@{
    Layout = "_Layout";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @* タイトルを中央寄せにし、ログイン画面と余白を合わせる *@
            <h2 class="text-center mb-4">@ViewBag.Title</h2>

            @* 追加 *@
            <div class="menu-desc-area">
                <p id="description-text" class="font-size: 1rem">実施したい機能を選択してください。</p>
            </div>

            <div class="list-group">
                <form asp-action="Menu" method="post">
                    <div class="d-grid gap-2">

                        @* 追加　従業員情報関連機能をカード化 *@
                        <div class="menu-card">
                            <div class="d-flex align-items-center mb-3">
                                <div class="menu-card-icon">
                                    <span class="fs-5">👤</span>
                                </div>
                                <h4 class="menu-card-title">従業員管理</h4>
                            </div>

                            @* 追記　data-desc属性の追加 *@
                            <div class="d-grid gap-2">
                                <button type="submit" name="btn_action" value=@(ActionValues.Insert)
                                        class="btn-outline-primary"
                                        data-desc="新規の従業員情報をシステムに登録します。">
                                    従業員登録
                                </button>

                                <button type="submit" name="btn_action" value=@(ActionValues.List)
                                        class="btn-outline-primary"
                                        data-desc="従業員の一覧を表示します。選択したデータの変更・削除もここから行えます。">
                                    一覧・編集
                                </button>
                            </div>
                        </div>

                        @* 追加　資格情報関連機能をカード化 *@
                        <div class="menu-card">
                            <div class="d-flex align-items-center mb-3">
                                <div class="menu-card-icon">
                                    <span class="fs-5">🪪</span>
                                </div>
                                <h4 class="menu-card-title">資格管理</h4>
                            </div>

                            @* 追記　data-desc属性の追加 *@
                            <button type="submit" name="btn_action" value=@(ActionValues.License) class="btn-outline-primary"
                                    data-desc="従業員が保有する資格の確認や、追加・削除などの編集を行います。">
                                従業員保有資格管理
                            </button>
                        </div>
                        <hr class="my-3" />

                        @* 追記　data-desc属性の追加 *@
                        <button type="submit" name="btn_action" value=@(ActionValues.Logout) class="btn-danger-filled"
                                data-desc="システムからログアウトし、ログイン画面に戻ります。">
                            ログアウト
                        </button>

                        @* 削除（以下はテスト用のため、完成時は表示されない） *@
                        @* <hr class="my-3" /> *@
                        <button type="submit" name="btn_action" value=@(ActionValues.Demo) class="btn-outline-danger">
                            テスト用メニュー
                        </button>
                    </div>
                </form>
            </div>

            @* メッセージエリアも同じ幅の中に収める *@
            @if (ViewBag.Caption != null)
            {
                <div class="alert alert-danger mt-4">
                    <strong>@ViewBag.Caption</strong><br />
                    @ViewBag.Msg
                </div>
            }


        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var descArea = document.getElementById('description-text');
            var buttons = document.querySelectorAll('button[data-desc]');
            var defaultText = descArea.textContent;

            // タイマーを管理する変数（乗ったとき・離れたとき共通）
            var hoverTimer;

            buttons.forEach(function (button) {
                // 1. マウスが乗ったとき
                button.addEventListener('mouseenter', function () {
                    // 乗った瞬間、これまでのタイマー（離れたときの戻る処理など）をすべてキャンセル
                    clearTimeout(hoverTimer);

                    var newDesc = this.getAttribute('data-desc');

                    // 0.15秒以上マウスが滞在したときだけ説明文を書き換える
                    hoverTimer = setTimeout(function () {
                        descArea.textContent = newDesc;
                    }, 150);
                });

                // 2. マウスが離れたとき
                button.addEventListener('mouseleave', function () {
                    // 乗ったときのタイマーを一度キャンセル
                    clearTimeout(hoverTimer);

                    /* 離れてから 0.2秒（200ミリ秒）待ってから元の文に戻す */
                    hoverTimer = setTimeout(function () {
                        descArea.textContent = defaultText;
                    }, 200); // 離したあとの余韻の長さです。お好みで 150 〜 300 あたりで微調整してください
                });
            });
        });
    </script>
}