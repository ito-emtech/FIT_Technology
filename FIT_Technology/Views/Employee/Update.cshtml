@{
   
}
@model FIT_Technology.Models.Entities.EmployeeEntity

<div class="col-md-6 mx-auto text-center">
    <h2>従業員情報変更</h2>
    <div class="menu-desc-area">
        <span>選択した従業員に対する操作を選択してください。</span>
    </div>
    <hr />
    <form method="post">
        <table class="table">
            <tr>
                <td>従業員コード</td>
                <td>@Model?.EmpCd</td>
                <input type="hidden" name="empcd" value="@Model?.EmpCd" />
                <td></td>
            </tr>
            <tr>
                <td>氏名（漢字）</td>
                <td>
                    <input type="text" name="lastnm" value="@Model?.LastNm" placeholder="例：山田" />
                    <br /><span asp-validation-for="LastNm" class="text-danger"></span>
                </td>
                <td>
                    <input type="text" name="firstnm" value="@Model?.FirstNm" placeholder="例：太郎" />
                    <br /><span asp-validation-for="FirstNm" class="text-danger"></span>
                </td>
            </tr>
            <tr>
                <td>氏名（カナ）</td>
                <td>
                    <input type="text" name="lastnmkana" value="@Model?.LastNmKana" placeholder="例：ヤマダ" />
                    <br /><span asp-validation-for="LastNmKana" class="text-danger"></span>
                </td>
                <td>
                    <input type="text" name="firstnmkana" value="@Model?.FirstNmKana" placeholder="例：タロウ" />
                    <br /><span asp-validation-for="FirstNmKana" class="text-danger"></span>
                </td>
            </tr>
            <tr>
                <td>性別</td>
                <td>
                    <select name="gendercd">
                        @for (int i = 0; i < ViewBag.GenderInfo.Count; i++)
                        {
                            <option value="@ViewBag.GenderInfo[i].GenderCd" selected="@(Model?.GenderCd == ViewBag.GenderInfo[i].GenderCd)">@ViewBag.GenderInfo[i].GenderNm</option>
                        }
                        
                    </select>
                </td>
                <td></td>
            </tr>
            <tr>
                <td>生年月日</td>
                <td>@Model?.BirthDate.ToString("yyyy年MM月dd日")</td>
                <input type="hidden" name="birthdate" value="@Model?.BirthDate" />
                <td></td>
            </tr>
            <tr>
                <td>所属</td>
                <td>
                    <select name="sectioncd">
                        @for (int i = 0; i < ViewBag.SectionInfo.Count; i++)
                        {
                            <option value="@ViewBag.SectionInfo[i].SectionCd" selected="@(Model?.SectionCd == ViewBag.SectionInfo[i].SectionCd)">@ViewBag.SectionInfo[i].SectionNm</option>
                        }
                        
                    </select>
                </td>
                <td></td>
            </tr>
            <tr>
                <td>入社日</td>
                <td>@Model?.EmpDate.ToString("yyyy年MM月dd日")</td>
                <input type="hidden" name="empdate" value="@Model?.EmpDate" />
                <td></td>
            </tr>
        </table><br />
        <button type="submit" class="btn-primary-filled" name="btn_action" value="result">変更</button>
        <hr>
        <button type="submit" class="btn btn-secondary w-100" name="btn_action" value="cancel">戻る</button>
    </form>

</div>