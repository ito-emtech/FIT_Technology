@* 💡 ファイルの1行目に、このViewが使うEntityの型を宣言します *@
@model FIT_Technology.Models.Entities.EmployeeEntity

<div class="text-center">
    <h1 class="display-4">従業員情報登録</h1>
    <form method="post">
        <table style="margin-left: auto; margin-right: auto; border:solid">
            <tr>
                <td style="border:solid">従業員コード</td>
                <td style="border:solid">
                    <input type="text" name="empcd" value="@Model?.EmpCd" />
                    <br /><span asp-validation-for="EmpCd" class="text-danger"></span>
                </td>
                <td style="border:solid"></td>
            </tr>
            <tr>
                <td style="border:solid">氏名（漢字）</td>
                <td style="border:solid">
                    <input type="text" name="lastnm" value="@Model?.LastNm" />
                    <br /><span asp-validation-for="LastNm" class="text-danger"></span>
                </td>
                <td style="border:solid">
                    <input type="text" name="firstnm" value="@Model?.FirstNm" />
                    <br /><span asp-validation-for="FirstNm" class="text-danger"></span>
                </td>
            </tr>
            <tr>
                <td style="border:solid">氏名（カナ）</td>
                <td style="border:solid">
                    <input type="text" name="lastnmkana" value="@Model?.LastNmKana" />
                    <br /><span asp-validation-for="LastNmKana" class="text-danger"></span>
                </td>
                <td style="border:solid">
                    <input type="text" name="firstnmkana" value="@Model?.FirstNmKana" />
                    <br /><span asp-validation-for="FirstNmKana" class="text-danger"></span>
                </td>
            </tr>
            <tr>
                <td style="border:solid">性別</td>
                <td style="border:solid">
                    <select name="gendercd">
                        <option value="0" selected="@(Model?.GenderCd == 0)">不明</option>
                        <option value="1" selected="@(Model?.GenderCd == 1)">男性</option>
                        <option value="2" selected="@(Model?.GenderCd == 2)">女性</option>
                        <option value="9" selected="@(Model?.GenderCd == 9)">その他</option>
                    </select>
                    <br /><span asp-validation-for="GenderCd" class="text-danger"></span>
                </td>
                <td style="border:solid"></td>
            </tr>
            <tr>
                <td style="border:solid">生年月日</td>
                <td style="border:solid">
                    <input type="date" name="birthdate" value="@Model?.BirthDate.ToString("yyyy-MM-dd")" />
                    <br /><span asp-validation-for="BirthDate" class="text-danger"></span>
                </td>
                <td style="border:solid"></td>
            </tr>
            <tr>
                <td style="border:solid">所属</td>
                <td style="border:solid">
                    <select name="sectioncd">
                        <option value="A1" selected="@(Model?.SectionCd == "A1")">管理部</option>
                        <option value="A2" selected="@(Model?.SectionCd == "A2")">総務部</option>
                        <option value="B1" selected="@(Model?.SectionCd == "B1")">開発部</option>
                        <option value="C1" selected="@(Model?.SectionCd == "C1")">営業部</option>
                    </select>
                    <br /><span asp-validation-for="SectionCd" class="text-danger"></span>
                </td>
                <td style="border:solid"></td>
            </tr>
            <tr>
                <td style="border:solid">入社日</td>
                <td style="border:solid">
                    <input type="date" name="empdate" value="@Model?.EmpDate.ToString("yyyy-MM-dd")" />
                    <br /><span asp-validation-for="EmpDate" class="text-danger"></span>
                </td>
                <td style="border:solid"></td>
            </tr>
        </table><br />
        <button type="submit" name="btn_action" value="result">登録</button>
        <button type="submit" name="btn_action" value="cancel">戻る</button>
    </form>
</div>