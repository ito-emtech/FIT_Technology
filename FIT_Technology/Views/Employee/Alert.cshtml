@{
}
<div class="text-center">
    <h1 class="display-4">削除確認</h1>
    <form method="post">
        @for(int i = 0; i < ViewBag.Info.Count; i++)
        {
            <div>従業員コード：@ViewBag.Info.EmpCd　氏名：@ViewBag.Info.Name</div>
        }
        <div>上記の従業員情報を削除します。<br>よろしければ【削除】を押してください。</div>
        <button type="submit" name="btn_action" value="result">登録</button>
        <button type="submit" name="btn_action" value="cancel">戻る</button>
    </form>

</div>