@model List<FIT_Technology.Models.Entities.GetLicenseEntity>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<div class="text-center">
    <h1>保有資格一覧</h1>

    <div>
        @* 選択した従業員コードと名前表示 *@
        従業員コード： @(ViewBag.ViewName)
        氏名：
    </div>

    <hr />

    <form action="/License/List" method="post">
        <table>
            <tr>
                <th>　</th>
                <th>資格名</th>
                <th>取得日</th>
            </tr>

            @* foreach構文*@
            @foreach (var item in Model)
            {
                <tr>
                    @* チェックボックスのvalueには、そのデータの資格コードを入力*@
                    <td><input type="checkbox" name="license_cd" value="@item.LicenseCd"></td>

                    @* ループで取り出した「現在の1件分」のデータを表示*@
                    <td>@item.LicenseCd</td>
                    <td>@item.GetLicenseDate.ToString("yyyy年MM月dd日")</td>
                </tr>
            }
           
        </table><br />


        <button type="submit" name="btn_action" value="cancel">戻る</button>

       
        <button type="submit" name="btn_action" value="alert">削除</button>

    </form>
</div>
