@model List<FIT_Technology.Models.Entities.GetLicenseEntity>
@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<div class="text-center">
    <h1>削除確認</h1>
    <form action="/License/Alert" method="post">

        @* 選択した従業員コードと名前表示 *@

        従業員コード：@(ViewBag.ViewName)

        氏名：
        
        <br />

        @* 選択した従業員の削除したい資格名と取得日を表示（画面設計図通り複数の場合の下書き） *@

        @foreach (var license in Model)
        {
            <li>資格名：@(license.LicenseCd) 取得日：@license.GetLicenseDate.ToString("yyyy年MM月dd日")</li>
        }


        <p>上記の資格情報を削除します。</p >
        <p>よろしければ【削除】を押してください。</p>

        <button type="submit" name="btn_action" value="result">削除</button>

        <button type="submit" name="btn_action" value="cancel">キャンセル</button><br />

    </form>
</div>