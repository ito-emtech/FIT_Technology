@model FIT_Technology.Models.Entities.UserEntity

@{
    Layout = "_Layout";
    var displayTitle = ViewBag.ViewTitle ?? "システム通知";
    var btnView = ViewBag.ButtonView ?? "次に進む";
}

<style>
    .view-msg{
        white-space: pre-line;
        word-break: break-all;
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-4">

            <h2 class="text-center mb-4">@(displayTitle)</h2>

            <div class="card shadow-sm">
                <div class="card-body p-4">

                    @* メッセージ本文：左寄せ・自動折り返し *@
                    <div class="card-text fs-5 mb-4 text-start view-msg">@ViewBag.Msg</div>

                    @* ボタン：カード中央寄りに配置（d-gridで横幅いっぱい） *@
                    <div class="d-grid">
                        <a asp-controller="Account" asp-action="Menu" class="btn btn-primary">
                            @(btnView)
                        </a>
                    </div>
                </div>

                @if (ViewBag.Caption != null)
                {
                    <div class="card-footer bg-light text-danger small">
                        <strong>補足:</strong> @ViewBag.Caption
                    </div>
                }
            </div>

        </div>
    </div>
</div>