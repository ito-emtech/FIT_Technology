@using FIT_Technology.Models.Constants
@model List<FIT_Technology.Models.Entities.GetLicenseEntity>

@{
    Layout = "_Layout";
}

<style>
    /* チェックされた行の通常の背景色と文字色 */
    .table.license-table tbody tr:has(.form-check-input:checked) td {
        background-color: #f8d7da !important;
        color: #842029 !important;
        transition: background-color 0.15s ease-in-out;
    }

    /* マウスが乗ったとき（hover）も選択時の背景色をキープする設定 */
    .table-hover.license-table tbody tr:has(.form-check-input:checked):hover td {
        background-color: #f5c2c7 !important; /* ホバー時はわずかに濃い赤にすると自然です */
        color: #842029 !important;
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @* 画面タイトル *@
            <h2 class="text-center mb-4">保有資格一覧</h2>

            @* 画面説明 *@
            <div class="menu-desc-area">
                <span>選択した資格を削除できます。</span>
            </div>

            @if (ViewBag.ErrorMsg != null)
            {
                <div class="alert alert-danger text-center p-2" role="alert">
                    <small>@ViewBag.ErrorMsg</small>
                </div>
            }

            <div class="menu-card">
                @* 操作者の表示 *@
                <h5 class="text-muted text-start mb-1"> @ViewBag.ViewName</h5>

                <hr class="my-3" />

                <form method="post">
                    <div class="table-responsive mb-4">
                        <table class="table table-bordered table-hover align-middle license-table">
                            <thead class="table-light">
                                <tr class="text-center">
                                    <th style="width: 20%;">削除選択</th>
                                    <th style="width: 20%;">資格コード</th>
                                    <th style="width: 30%;">資格名</th> @* ★ヘッダー追加 *@
                                    <th style="width: 30%;">取得日</th>
                                </tr>
                            </thead>
                            <tbody class="license-table">
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var item in Model)
                                    {
                                        var domId = $"lic_{item.EmpCd}_{item.LicenseCd}";

                                        <tr class="license-table">
                                            <td class="text-center">
                                                <input type="checkbox" name="license_cd" value="@item.LicenseCd" id="@domId" class="form-check-input" />
                                            </td>
                                            <td>
                                                <label for="@domId" class="w-100 m-0 d-block text-center" style="cursor: pointer;">@item.LicenseCd</label>
                                            </td>
                                            <td>
                                                <label for="@domId" class="w-100 m-0 d-block text-start ps-2" style="cursor: pointer;">
                                                    @item.LicenseNm
                                                </label>
                                            </td>
                                            <td>
                                                <label for="@domId" class="w-100 m-0 d-block text-center" style="cursor: pointer">
                                                    @item.GetLicenseDate.ToString("yyyy年MM月dd日")
                                                </label>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="4" class="text-center text-muted py-4">
                                            保有している資格はありません。
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" name="btn_action" value="@ActionValues.Alert" class="btn btn-danger" @(Model != null && Model.Any() ? "" : "disabled")>
                            選択した資格の削除確認画面へ
                        </button>
                    </div>
                </form>
            </div>

            <hr class="my-3" />

            <div>
                <div class="d-grid gap-2">
                    <a asp-action="LicenseMenu" class="btn btn-secondary">資格管理メニューに戻る</a>
                </div>
            </div>
        </div>
    </div>
</div>
