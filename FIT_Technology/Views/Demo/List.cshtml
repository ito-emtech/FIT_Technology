@using FIT_Technology.Models.Constants
@model List<FIT_Technology.Models.Entities.GetLicenseEntity>

@{
    Layout = "_Layout";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <h2 class="text-center mb-4">保有資格一覧</h2>

            @if (ViewBag.ErrorMsg != null)
            {
                <div class="alert alert-danger text-center p-2" role="alert">
                    <small>@ViewBag.ErrorMsg</small>
                </div>
            }

            <form method="post">
                <div class="table-responsive mb-4">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr class="text-center">
                                <th style="width: 15%;">削除選択</th>
                                <th style="width: 35%;">資格コード</th>
                                <th style="width: 50%;">取得日</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    @* 複合キーを意識し、一意になるDOM IDを生成 *@
                                    var domId = $"lic_{item.EmpCd}_{item.LicenseCd}";

                                    <tr>
                                        <td class="text-center">
                                            @* コントローラーの引数 string[] license_cd にバインドさせるため name="license_cd" *@
                                            <input type="checkbox" name="license_cd" value="@item.LicenseCd" id="@domId" class="form-check-input" />
                                        </td>
                                        <td>
                                            <label for="@domId" class="w-100 m-0 d-block text-center" style="cursor: pointer;">@item.LicenseCd</label>
                                        </td>
                                        <td>
                                            @* 日付を YYYY-MM-DD 形式で綺麗に整形して表示 *@
                                            <label for="@domId" class="w-100 m-0 d-block text-center" style="cursor: pointer;">
                                                @item.GetLicenseDate.ToString("yyyy-MM-dd")
                                            </label>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                @* --- 画面遷移確認用のデモデータ --- *@
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="license_cd" value="L0001" id="lic_demo_L0001" class="form-check-input" />
                                    </td>
                                    <td>
                                        <label for="lic_demo_L0001" class="w-100 m-0 d-block text-center" style="cursor: pointer;">L0001</label>
                                    </td>
                                    <td>
                                        <label for="lic_demo_L0001" class="w-100 m-0 d-block text-center" style="cursor: pointer;">2026-05-10</label>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-center">
                                        <input type="checkbox" name="license_cd" value="L0002" id="lic_demo_L0002" class="form-check-input" />
                                    </td>
                                    <td>
                                        <label for="lic_demo_L0002" class="w-100 m-0 d-block text-center" style="cursor: pointer;">L0002</label>
                                    </td>
                                    <td>
                                        <label for="lic_demo_L0002" class="w-100 m-0 d-block text-center" style="cursor: pointer;">2026-05-31</label>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" name="btn_action" value="@ActionValues.Alert" class="btn btn-danger">
                        選択した資格の削除確認画面へ
                    </button>
                    <a asp-action="LicenseMenu" class="btn btn-outline-secondary">LicenseMenuに戻る</a>
                </div>
            </form>
        </div>
    </div>
</div>