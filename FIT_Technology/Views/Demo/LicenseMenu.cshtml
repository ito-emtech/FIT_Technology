@using FIT_Technology.Models.Constants
@model List<FIT_Technology.Models.ViewModels.LicenseMenuRowViewModel>

@{
    Layout = "_Layout";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-9">
            @* 項目が増えたため、横幅を少し広げました (col-md-8 -> 9) *@
            <h2 class="text-center mb-4">@ViewBag.ViewTitle</h2>

            @if (ViewBag.ErrorMsg != null)
            {
                <div class="alert alert-danger text-center p-2" role="alert">
                    <small>@ViewBag.ErrorMsg</small>
                </div>
            }

            <form method="post">
                <div class="table-responsive mb-4">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light">
                            <tr class="text-center">
                                <th style="width: 10%;">選択</th>
                                <th style="width: 20%;">従業員コード</th>
                                <th style="width: 50%;">氏名</th>
                                <th style="width: 20%;">部署</th> @* 部署ヘッダを追加 *@
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    var domId = $"emp_{item.EmpCd}";

                                    <tr>
                                        <td class="text-center">
                                            <input type="radio" name="emp_cd" value="@item.EmpCd" id="@domId" class="form-check-input" />
                                        </td>
                                        <td>
                                            <label for="@domId" class="w-100 m-0 d-block text-center" style="cursor: pointer;">@item.EmpCd</label>
                                        </td>
                                        <td>
                                            <label for="@domId" class="w-100 m-0 d-block" style="cursor: pointer;">
                                                @item.LastNm @item.FirstNm（@item.LastNmKana @item.FirstNmKana）
                                            </label>
                                        </td>
                                        <td>
                                            <label for="@domId" class="w-100 m-0 d-block text-start ps-2" style="cursor: pointer;">
                                                @item.DisplaySection
                                            </label>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                @* --- 画面遷移確認用のデモデータ --- *@
                                <tr>
                                    <td class="text-center">
                                        <input type="radio" name="emp_cd" value="EMP001" id="emp_EMP001" class="form-check-input" />
                                    </td>
                                    <td>
                                        <label for="emp_EMP001" class="w-100 m-0 d-block text-center" style="cursor: pointer;">EMP001</label>
                                    </td>
                                    <td>
                                        <label for="emp_EMP001" class="w-100 m-0 d-block" style="cursor: pointer;">山田 太郎（ヤマダ タロウ）</label>
                                    </td>
                                    <td>
                                        <label for="emp_EMP001" class="w-100 m-0 d-block text-center" style="cursor: pointer;">01</label>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="text-center">
                                        <input type="radio" name="emp_cd" value="EMP002" id="emp_EMP002" class="form-check-input" />
                                    </td>
                                    <td>
                                        <label for="emp_EMP002" class="w-100 m-0 d-block text-center" style="cursor: pointer;">EMP002</label>
                                    </td>
                                    <td>
                                        <label for="emp_EMP002" class="w-100 m-0 d-block" style="cursor: pointer;">鈴木 花子（スズキ ハナコ）</label>
                                    </td>
                                    <td>
                                        <label for="emp_EMP002" class="w-100 m-0 d-block text-center" style="cursor: pointer;">02</label>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-grid gap-2">
                    <div class="row g-2">
                        <div class="col">
                            <button type="submit" name="btn_action" value="@ActionValues.List" class="btn btn-outline-primary w-100">
                                選択者の資格一覧を表示
                            </button>
                        </div>
                        <div class="col">
                            <button type="submit" name="btn_action" value="@ActionValues.Insert" class="btn btn-outline-primary w-100">
                                選択者の資格登録
                            </button>
                        </div>
                    </div>
                    <hr class="my-3" />
                    <button type="submit" name="btn_action" value="employeeInsert" class="btn btn-primary">
                        従業員の新規登録へ
                    </button>
                    <a asp-controller="Account" asp-action="Menu" class="btn btn-outline-secondary mt-2">
                        戻る（トップメニューへ）
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>