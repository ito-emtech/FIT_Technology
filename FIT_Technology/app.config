<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<add name="empdb"
			 connectionString="
			 Data Source=localhost; 
			 Initial Catalog=emp_db;
			 User ID=embexU; 
			 Password=embexP;
			 Connect Timeout=60; 
			 Persist Security Info=True;
			 Encrypt=True;
			 TrustServerCertificate=True;
			 " />
		<!-- ローカルファイル -->
		<add name="local"
			 connectionString="
             Data Source=localhost\SQLEXPRESS; 
             Initial Catalog=emp_db;
             User ID=embexU; 
             Password=embexP;
             Connect Timeout=60; 
             Persist Security Info=True;
             Encrypt=True;
             TrustServerCertificate=True;
         " />
	</connectionStrings>
